platform :ios, '13.0' # Возвращаем базовую 13.0 под твои плагины

flutter_root = ENV['FLUTTER_ROOT'] || '..'
require File.expand_path(File.join(flutter_root, 'packages', 'flutter_tools', 'bin', 'podhelper.rb'))

install! 'cocoapods', :deterministic_uuids => false

target 'Runner' do
  use_frameworks! :linkage => :static
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.expand_path(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_managed_attributes(target) if respond_to?(:flutter_additional_ios_managed_attributes)

    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'

      # ЖЕСТКИЙ ФИКС: Если CocoaPods пытается подсунуть флаг -G, мы его полностью стираем
      if config.build_settings['OTHER_CFLAGS']
        config.build_settings['OTHER_CFLAGS'].gsub!(/-G\b/, '')
      end
      if config.build_settings['OTHER_CPLUSPLUSFLAGS']
        config.build_settings['OTHER_CPLUSPLUSFLAGS'].gsub!(/-G\b/, '')
      end

      # Дополнительно глушим предупреждения компилятора Xcode на сервере
      config.build_settings['WARNING_CFLAGS'] = '-Wno-invalid-command-line-argument -Wno-unknown-argument'
    end
  end
end