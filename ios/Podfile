platform :ios, '14.0'

flutter_root = ENV['FLUTTER_ROOT'] || '..'
require File.expand_path(File.join(flutter_root, 'packages', 'flutter_tools', 'bin', 'podhelper.rb'))

install! 'cocoapods', :deterministic_uuids => false

target 'Runner' do
  use_frameworks! :linkage => :static
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.expand_path(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_managed_attributes(target) if respond_to?(:flutter_additional_ios_managed_attributes)

    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'

      # ЖЕСТКИЙ ФИКС: Принудительно прописываем пути к заголовочным файлам Flutter для всех плагинов
      config.build_settings['HEADER_SEARCH_PATHS'] = '$(inherited) "$(SRCROOT)/Flutter" "$(SRCROOT)/Pods/Headers/Public" "$(SRCROOT)/Pods/Headers/Public/Flutter"'
      config.build_settings['FRAMEWORK_SEARCH_PATHS'] = '$(inherited) "$(SRCROOT)/Flutter"'

      # Разрешаем сборку на ARM64 без валидации кода (для no-codesign на CI)
      config.build_settings['ONLY_ACTIVE_ARCH'] = 'YES'
    end
  end
end