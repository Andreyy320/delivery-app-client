platform :ios, '14.0' # Поднимаем версию до 14.0, Firebase ниже часто не переваривает

target 'Runner' do
  use_frameworks! :linkage => :static # Форсируем статическую линковку плагинов
  use_modular_headers!

  # Сами объявляем базовые поды Flutter, если хелпер не подтягивается автоматически
  pod 'Flutter'
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
      config.build_settings['ENABLE_BITCODE'] = 'NO' # Отключаем биткод, он часто рушит сборку Firebase
    end
  end
end